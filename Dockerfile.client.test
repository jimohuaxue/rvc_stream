# RVC Stream Client - Instant Test Image
# Minimal Dockerfile for immediate testing
FROM python:3.11-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# Install ONLY core dependencies (no ffmpeg, no portaudio)
RUN pip install --no-cache-dir \
    websockets==11.0 \
    numpy==1.24.0 \
    pyyaml==6.0

# Copy application code
COPY src/ ./src/

# Default command
CMD ["python3", "-m", "src.rvc_client", "--help"]